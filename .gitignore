# === Root Monorepo .gitignore ===

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
out/
*.bundle
*.jsbundle

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml
.project
.classpath
.settings/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
junit.xml

# Temporary files
tmp/
temp/
*.tmp
.cache/

# === Backend Specific ===
backend/**/.env
backend/**/dist/

# === ZK Specific ===
zk/build/
zk/**/*.r1cs
zk/**/*.wasm
zk/**/*.zkey
zk/**/*.vkey
*.ptau

# === Blockchain Specific ===
blockchain/artifacts/
blockchain/cache/
blockchain/typechain-types/
blockchain/.openzeppelin/
blockchain/deployments/
blockchain/coverage/
blockchain/coverage.json

# === Mobile App Specific (already in apps/mobile/.gitignore but adding key ones here) ===
# iOS
apps/mobile/ios/Pods/
apps/mobile/ios/build/
apps/mobile/ios/**/*.xcworkspace
!apps/mobile/ios/**/*.xcworkspace/contents.xcworkspacedata
apps/mobile/ios/**/*.xcuserstate
apps/mobile/ios/DerivedData/

# Android
apps/mobile/android/app/build/
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/local.properties
apps/mobile/android/**/*.keystore
!apps/mobile/android/app/debug.keystore
apps/mobile/android/.cxx/

# Metro
.metro-health-check*
