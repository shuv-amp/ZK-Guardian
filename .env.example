# ========================================
# ZK Guardian Environment Variables
# ========================================
# Copy this file to .env and fill in values

# ----------------------------------------
# Gateway Configuration
# ----------------------------------------
PORT=3000
NODE_ENV=development
ENABLE_SYNTHETIC_CONSENT=false
ENABLE_BATCH_AUDIT=false
CIRCUIT_ARTIFACTS_DIR=./circuits/build

# HAPI FHIR Server
HAPI_FHIR_URL=http://localhost:8080/fhir

# SMART on FHIR OAuth
SMART_AUTH_MODE=local
SMART_ISSUER=
SMART_AUTHORIZATION_ENDPOINT=
SMART_TOKEN_ENDPOINT=
SMART_INTROSPECTION_ENDPOINT=
SMART_REVOCATION_ENDPOINT=
SMART_JWKS_URI=
SMART_CLIENT_ID=zk-guardian-mobile
SMART_CLIENT_SECRET=
SMART_AUDIENCE=
SMART_PRIVATE_JWK=
SMART_REDIRECT_URIS=
ALLOW_DEV_BYPASS=false

# Consent WebSocket
CONSENT_TIMEOUT_MS=60000

# ----------------------------------------
# Blockchain (Polygon Amoy Testnet)
# ----------------------------------------
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# Deployer wallet (for contract deployment)
DEPLOYER_PRIVATE_KEY=0x...

# Gateway wallet (for audit submissions)
GATEWAY_PRIVATE_KEY=0x...

# Deployed contract addresses (fill after deployment)
AUDIT_CONTRACT_ADDRESS=0x...
CONSENT_REVOCATION_REGISTRY_ADDRESS=0x...
CREDENTIAL_REGISTRY_ADDRESS=0x...

# Optional explicit artifact hashes. If unset, production expects checksums.sha256 at repo root.
CIRCUIT_WASM_SHA256=
CIRCUIT_ZKEY_SHA256=
CIRCUIT_VKEY_SHA256=

# PolygonScan API (for contract verification)
POLYGONSCAN_API_KEY=

# ----------------------------------------
# Push Notifications (optional)
# ----------------------------------------
# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=

# Rate limiting overrides (optional)
RATE_LIMIT_BREAK_GLASS_LIMIT=
RATE_LIMIT_BREAK_GLASS_WINDOW_SEC=
RATE_LIMIT_DEFAULT_LIMIT=
RATE_LIMIT_DEFAULT_WINDOW_SEC=

# ----------------------------------------
# Monitoring (optional)
# ----------------------------------------
PROMETHEUS_ENABLED=false
GRAFANA_ADMIN_PASSWORD=admin

# ----------------------------------------
# Mobile App (Expo)
# ----------------------------------------
EXPO_PUBLIC_GATEWAY_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=ws://localhost:3000/ws/consent
EXPO_PUBLIC_POLYGON_RPC=https://rpc-amoy.polygon.technology
