{
    "name": "@zk-guardian/sdk",
    "version": "0.1.0",
    "description": "ZK Guardian SDK for generating and verifying zero-knowledge proofs for healthcare consent",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./circuits": {
            "import": "./dist/circuits/index.mjs",
            "require": "./dist/circuits/index.js",
            "types": "./dist/circuits/index.d.ts"
        },
        "./consent": {
            "import": "./dist/consent/index.mjs",
            "require": "./dist/consent/index.js",
            "types": "./dist/consent/index.d.ts"
        }
    },
    "files": [
        "dist",
        "circuits"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "circomlibjs": "^0.1.7",
        "ethers": "^6.9.0",
        "snarkjs": "^0.7.3"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "tsup": "^8.0.0",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    },
    "peerDependencies": {
        "ethers": "^6.0.0"
    },
    "keywords": [
        "zk-snark",
        "healthcare",
        "hipaa",
        "consent",
        "privacy",
        "blockchain",
        "fhir"
    ],
    "author": "ZK Guardian Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/zk-guardian/zk-guardian"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}