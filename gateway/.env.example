# ZK Guardian Gateway Environment Variables
# Copy to .env and fill in values

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database (Required for production)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zkguardian

# ============================================
# Redis (Required for production rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# HAPI FHIR Server
# ============================================
HAPI_FHIR_URL=http://localhost:8080/fhir

# ============================================
# Blockchain (Polygon Amoy Testnet)
# ============================================
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
AUDIT_CONTRACT_ADDRESS=
GATEWAY_PRIVATE_KEY=

# ============================================
# SMART on FHIR OAuth
# ============================================
SMART_AUTH_MODE=local
SMART_ISSUER=
SMART_AUTHORIZATION_ENDPOINT=
SMART_TOKEN_ENDPOINT=
SMART_INTROSPECTION_ENDPOINT=
SMART_REVOCATION_ENDPOINT=
SMART_JWKS_URI=
SMART_CLIENT_ID=
SMART_CLIENT_SECRET=
SMART_AUDIENCE=
SMART_PRIVATE_JWK=
SMART_REDIRECT_URIS=
ALLOW_DEV_BYPASS=false

# Mock external SMART/OIDC drill (optional local rehearsal)
# SMART_AUTH_MODE=external
# SMART_ISSUER=http://127.0.0.1:4010
# SMART_AUTHORIZATION_ENDPOINT=http://127.0.0.1:4010/authorize
# SMART_TOKEN_ENDPOINT=http://127.0.0.1:4010/token
# SMART_INTROSPECTION_ENDPOINT=http://127.0.0.1:4010/introspect
# SMART_REVOCATION_ENDPOINT=http://127.0.0.1:4010/revoke
# SMART_JWKS_URI=http://127.0.0.1:4010/.well-known/jwks.json
# SMART_CLIENT_ID=zk-guardian-gateway
# SMART_CLIENT_SECRET=mock-smart-secret
# SMART_AUDIENCE=http://localhost:8080/fhir

# ============================================
# CORS (comma-separated origins or * for all)
# ============================================
CORS_ORIGINS=*

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Features
# ============================================
PROMETHEUS_ENABLED=true
BATCH_INTERVAL_MS=300000
BATCH_SIZE=10

# Rate limiting overrides (optional)
RATE_LIMIT_BREAK_GLASS_LIMIT=
RATE_LIMIT_BREAK_GLASS_WINDOW_SEC=
RATE_LIMIT_DEFAULT_LIMIT=
RATE_LIMIT_DEFAULT_WINDOW_SEC=

# ============================================
# Tracing (OpenTelemetry/Jaeger)
# ============================================
ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:4318/v1/traces

# ============================================
# Key Management
# ============================================
# Required for production - secure master password for local key encryption
KEY_MASTER_PASSWORD=

# ============================================
# Circuit Integrity (Optional)
# ============================================
# Canonical artifact root used by the gateway and Docker image
CIRCUIT_ARTIFACTS_DIR=../circuits/build

# Optional explicit hashes. If unset, production expects checksums.sha256 at the repo root.
CIRCUIT_WASM_SHA256=
CIRCUIT_ZKEY_SHA256=
CIRCUIT_VKEY_SHA256=

# ============================================
# Feature Flags
# ============================================
ENABLE_WORKER_POOL=false
ENABLE_SYNTHETIC_CONSENT=false
ENABLE_BATCH_AUDIT=false
