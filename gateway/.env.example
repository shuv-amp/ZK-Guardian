# ZK Guardian Gateway Environment Variables
# Copy to .env and fill in values

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database (Required for production)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zkguardian

# ============================================
# Redis (Required for production rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# HAPI FHIR Server
# ============================================
HAPI_FHIR_URL=http://localhost:8080

# ============================================
# Blockchain (Polygon Amoy Testnet)
# ============================================
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
AUDIT_CONTRACT_ADDRESS=
GATEWAY_PRIVATE_KEY=

# ============================================
# SMART on FHIR OAuth
# ============================================
SMART_ISSUER=
SMART_CLIENT_ID=

# ============================================
# CORS (comma-separated origins or * for all)
# ============================================
CORS_ORIGINS=*

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Features
# ============================================
PROMETHEUS_ENABLED=true
BATCH_INTERVAL_MS=300000
BATCH_SIZE=10

# ============================================
# Tracing (OpenTelemetry/Jaeger)
# ============================================
ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:4318/v1/traces

# ============================================
# Key Management
# ============================================
# Required for production - secure master password for local key encryption
KEY_MASTER_PASSWORD=

# ============================================
# Circuit Integrity (Optional)
# ============================================
# Set these to verify circuit files haven't been tampered with
# Generate with: sha256sum circuits/build/AccessIsAllowedSecure/*.wasm
CIRCUIT_WASM_SHA256=
CIRCUIT_ZKEY_SHA256=

# ============================================
# Feature Flags
# ============================================
ENABLE_WORKER_POOL=false
